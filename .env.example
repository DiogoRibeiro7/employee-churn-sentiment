# Example environment file. Copy to `.env` and adjust as needed.
# Every value overrides the matching key in configs/*.yaml.
#
# Naming: ECS_<SECTION>__<KEY> (double underscore separates nesting).
# Values are parsed as YAML, so numbers/booleans/lists work as written.

# Deployment environment label (development | staging | production).
ECS_ENVIRONMENT=development

# --- Model overrides ---
# ECS_MODEL__MODEL_NAME=random_forest
# ECS_MODEL__RANDOM_STATE=42
# ECS_MODEL__CALIBRATION_METHOD=sigmoid

# --- Data / schema overrides ---
# ECS_DATA__TARGET_COLUMN=churned
# ECS_DATA__TEXT_COLUMN=feedback

# --- Path overrides ---
# ECS_PATHS__ARTIFACTS_DIR=/var/models/churn

# --- Logging overrides ---
# ECS_LOGGING__LEVEL=DEBUG

# --- MLflow tracking (consumed by employee_churn.models.track) ---
# MLFLOW_TRACKING_URI=http://localhost:5000
